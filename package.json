{
  "name": "dep",
  "version": "0.18.3",
  "description": "A little Node.js dependency installer",
  "type": "module",
  "main": "lib/install.js",
  "scripts": {
    "release": "standard-version",
    "pretest": "standard \"lib/**/*.js\" \"bin/*.js\" \"test/*.js\" \"scripts/*.js\"",
    "test": "tap \"test/*.js\" --timeout 1000 --jobs=1 --disable-coverage",
    "test-ci": "tap \"test/*.js\" --timeout 1000 --jobs=1 --allow-incomplete-coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/depjs/dep.git"
  },
  "bin": {
    "dep": "./bin/dep.js",
    "depjs": "./bin/dep.js"
  },
  "keywords": [
    "npm"
  ],
  "author": "Daijiro Wachi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/depjs/dep/issues"
  },
  "homepage": "https://github.com/depjs/dep#readme",
  "bundleDependencies": [
    "cmd-shim",
    "fs-extra",
    "gunzip-maybe",
    "node-gyp",
    "npm-package-arg",
    "npm-path",
    "promise-each",
    "request",
    "semver",
    "tar-fs",
    "tar-stream",
    "update-notifier",
    "which",
    "yargs"
  ],
  "dependencies": {
    "cmd-shim": "^9.0.1",
    "fs-extra": "^11.3.5",
    "gunzip-maybe": "^1.4.2",
    "node-gyp": "^13.0.0",
    "npm-package-arg": "^14.0.0",
    "npm-path": "^2.0.4",
    "promise-each": "^2.2.0",
    "request": "^2.88.2",
    "semver": "^7.8.4",
    "tar-fs": "^3.1.2",
    "tar-stream": "^3.2.0",
    "update-notifier": "^7.3.1",
    "which": "^7.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "standard": "^17.1.2",
    "standard-version": "^9.5.0",
    "strong-npm-ls": "^1.0.10",
    "tap": "^21.7.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}

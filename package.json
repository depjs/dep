{
  "name": "dep",
  "version": "0.18.3",
  "description": "A little Node.js dependency installer",
  "main": "index.js",
  "scripts": {
    "release": "standard-version",
    "pretest": "standard \"lib/**/*.js\" \"bin/*.js\" \"test/*js\" \"scripts/*.js\"",
    "test": "tap \"test/*.js\" --timeout 1000 --jobs=1",
    "test-ci": "tap --coverage \"test/*.js\" --timeout 1000 --jobs=1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/depjs/dep.git"
  },
  "bin": {
    "dep": "./bin/dep.js",
    "depjs": "./bin/dep.js"
  },
  "keywords": [
    "npm"
  ],
  "author": "Daijiro Wachi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/depjs/dep/issues"
  },
  "homepage": "https://github.com/depjs/dep#readme",
  "bundleDependencies": [
    "gunzip-maybe",
    "node-gyp",
    "npm-package-arg",
    "npm-path",
    "promise-each",
    "request",
    "semver",
    "tar-fs",
    "tar-stream",
    "update-notifier",
    "which",
    "yargs"
  ],
  "dependencies": {
    "fs-extra": "^10.1.0",
    "gunzip-maybe": "^1.4.2",
    "node-gyp": "11.2.0",
    "npm-package-arg": "12.0.2",
    "npm-path": "^2.0.4",
    "promise-each": "^2.2.0",
    "request": "^2.88.2",
    "semver": "^7.3.2",
    "tar-fs": "3.0.10",
    "tar-stream": "3.1.7",
    "update-notifier": "^5.1.0",
    "which": "5.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "standard": "17.1.2",
    "standard-version": "^9.0.0",
    "strong-npm-ls": "^1.0.10",
    "tap": "21.1.0"
  },
  "engine": {
    "node": ">=10.0.0"
  }
}

{
  "name": "dep",
  "version": "1.4.4",
  "description": "A little Node.js dependency installer for module end-users",
  "type": "module",
  "main": "lib/install.js",
  "scripts": {
    "release": "standard-version",
    "pretest": "standard \"lib/**/*.js\" \"bin/*.js\" \"test/*.js\" \"test/helpers/*.js\" \"scripts/*.js\"",
    "test": "node scripts/test.js",
    "test-ci": "node scripts/test.js --coverage",
    "coverage": "node scripts/test.js --lcov"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/depjs/dep.git"
  },
  "bin": {
    "dep": "./bin/dep.js",
    "depjs": "./bin/dep.js"
  },
  "keywords": [
    "npm"
  ],
  "author": "Daijiro Wachi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/depjs/dep/issues"
  },
  "homepage": "https://github.com/depjs/dep#readme",
  "dependencies": {},
  "devDependencies": {
    "standard": "^17.1.2",
    "standard-version": "^9.5.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
